<?xml version="1.0"?>
<robot name="Puma560" xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:macro name="robot_mesh" params="name">
        <mesh filename="package://puma560_description/meshes/${name}" scale="${0.001*25.4} ${0.001*25.4} ${0.001*25.4}"/>
    </xacro:macro>

    <material name="blue">
        <color rgba="0 0 0.8 0.8"/>
    </material>
    <material name="red">
        <color rgba="0.8 0 0 0.8"/>
    </material>
    <material name="green">
        <color rgba="0 0.8 0 0.8"/>
    </material>

    <link name="world"/>

    <link name="link1">
        <visual>
            <geometry>
                <xacro:robot_mesh name="puma_link1.stl"/>
            </geometry>
            <origin rpy="0 0 1.570796325"/>
            <material name="green"/>
        </visual>
        <collision>
            <geometry>
                <xacro:robot_mesh name="puma_link1.stl"/>
            </geometry>
            <origin rpy="0 0 1.570796325"/>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="100.0"/>
            <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
        </inertial>
    </link>

    <link name="link2">
        <visual>
            <geometry>
                <xacro:robot_mesh name="puma_link2.stl"/>
            </geometry>
            <origin xyz="0 0 -0.1"/>
            <material name="red"/>
        </visual>
        <collision>
            <geometry>
                <xacro:robot_mesh name="puma_link2.stl"/>
            </geometry>
            <origin xyz="0 0 -0.1"/>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.1"/>
            <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
        </inertial>
    </link>

    <link name="link3">
        <visual>
            <geometry>
                <xacro:robot_mesh name="puma_link3.stl"/>
            </geometry>
            <origin xyz="0 0 0.1936"/>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <xacro:robot_mesh name="puma_link3.stl"/>
            </geometry>
            <origin xyz="0 0 0.1936"/>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.1"/>
            <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
        </inertial>
    </link>

    <link name="link4">
        <visual>
            <geometry>
                <xacro:robot_mesh name="puma_link4.stl"/>
            </geometry>
            <origin xyz="0 0 0"/>
            <material name="green"/>
        </visual>
        <collision>
            <geometry>
                <xacro:robot_mesh name="puma_link4.stl"/>
            </geometry>
            <origin xyz="0 0 0"/>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.1"/>
            <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
        </inertial>
    </link>

    <link name="link5">
        <visual>
            <geometry>
                <xacro:robot_mesh name="puma_link5.stl"/>
            </geometry>
            <origin rpy="0 0 1.570796325" xyz="0 0 0.3621"/>
            <material name="red"/>
        </visual>
        <collision>
            <geometry>
                <xacro:robot_mesh name="puma_link5.stl"/>
            </geometry>
            <origin rpy="0 0 1.570796325" xyz="0 0 0.3621"/>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.1"/>
            <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
        </inertial>
    </link>

    <link name="link6">
        <visual>
            <geometry>
                <xacro:robot_mesh name="puma_link6.stl"/>
            </geometry>
            <origin rpy="3.14159265 0 1.570796325"/>
            <material name="green"/>
        </visual>
        <collision>
            <geometry>
                <xacro:robot_mesh name="puma_link6.stl"/>
            </geometry>
            <origin rpy="3.14159265 0 1.570796325"/>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.1"/>
            <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
        </inertial>
    </link>

    <link name="link7">
        <visual>
            <geometry>
                <xacro:robot_mesh name="puma_link7.stl"/>
            </geometry>
            <origin xyz="0 0 -0.010"/>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <xacro:robot_mesh name="puma_link7.stl"/>
            </geometry>
            <origin xyz="0 0 -0.010"/>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.1"/>
            <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
        </inertial>
    </link>

    <joint name="base" type="fixed">
        <parent link="world"/>
        <child link="link1"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <joint name="joint1" type="revolute">
        <parent link="link1"/>
        <child link="link2"/>
        <origin xyz="0 0 0.6718" rpy="1.570796325 0 0"/>
        <axis xyz="0 1 0"/>
        <limit effort="1000.0" lower="-3.14159265" upper="3.14159265" velocity="2.0"/>
        <dynamics damping="1.0" friction="0.1"/>
    </joint>

    <joint name="joint2" type="revolute">
        <parent link="link2"/>
        <child link="link3"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit effort="1000.0" lower="-0.85521133" upper="3.99680399" velocity="2.0"/>
        <dynamics damping="1.0" friction="0.1"/>
    </joint>

    <joint name="joint3" type="revolute">
        <parent link="link3"/>
        <child link="link4"/>
        <origin xyz="0.4318 -0.0203 0.1501" rpy="0 0 -1.570796325"/>
        <axis xyz="0 0 1"/>
        <limit effort="1000.0" lower="-0.85521133" upper="3.99680399" velocity="2.0"/>
        <dynamics damping="1.0" friction="0.1"/>
    </joint>

    <joint name="joint4" type="revolute">
        <parent link="link4"/>
        <child link="link5"/>
        <origin xyz="0 0 0" rpy="1.570796325 0 1.570796325"/>
        <axis xyz="0 0 1"/>
        <limit effort="1000.0" lower="-3.31612558" upper="2.18166157" velocity="2.0"/>
        <dynamics damping="1.0" friction="0.1"/>
    </joint>

    <joint name="joint5" type="revolute">
        <parent link="link5"/>
        <child link="link6"/>
        <origin xyz="0 0 0.4331" rpy="1.570796325 0 0"/>
        <axis xyz="0 0 1"/>
        <limit effort="1000.0" lower="-1.74532925" upper="1.74532925" velocity="2.0"/>
        <dynamics damping="1.0" friction="0.1"/>
    </joint>

    <joint name="joint6" type="revolute">
        <parent link="link6"/>
        <child link="link7"/>
        <origin xyz="0 0.0558 0" rpy="-1.570796325 0 0"/>
        <axis xyz="0 0 1"/>
        <limit effort="1000.0" lower="-3.14159265" upper="3.14159265" velocity="2.0"/>
        <dynamics damping="1.0" friction="0.1"/>
    </joint>

    <ros2_control name="robot_hardware_interface" type="system">
        <hardware>
            <!--<plugin>gz_ros2_control/GazeboSimSystem</plugin>-->
            <plugin>puma560_description/RobotHardwareInterface</plugin>
        </hardware>
        
        <joint name="joint1">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <joint name="joint2">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <joint name="joint3">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <joint name="joint4">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <joint name="joint5">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <joint name="joint6">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
    </ros2_control>

    <!--<gazebo>
        <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
            <parameters>$(find puma560_description)/config/controllers.yaml</parameters>
        </plugin>
    </gazebo>-->
</robot>
