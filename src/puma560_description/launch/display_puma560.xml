<?xml version="1.0"?>
<launch> 
    <let name="robot_description" 
         value="$(command 'xacro $(find-pkg-share puma560_description)/urdf/puma560_robot.urdf.xacro')"/>
    
    <node pkg="robot_state_publisher" exec="robot_state_publisher" name="robot_state_publisher">
        <param name="robot_description" value="$(var robot_description)"/>
        <param name="use_sim_time" value="false"/>
    </node>

    <node pkg="tf2_ros" exec="static_transform_publisher" name="world_to_base" 
          args="0 0 0 0 0 0 world base_link"/> 
   
    <node pkg="joint_state_publisher_gui" exec="joint_state_publisher_gui" name="joint_state_publisher_gui">
        <param name="robot_description" value="$(var robot_description)"/>
        <param name="use_sim_time" value="false"/>
    </node>
    
    <node pkg="rviz2" exec="rviz2" name="rviz2" 
          args="-d $(find-pkg-share puma560_description)/config/puma560.rviz"/>
</launch>
